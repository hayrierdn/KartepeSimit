[Unit]
Description=Kartepe Simit QR Menu
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/kartepe-simit
Environment=NODE_ENV=production
Environment=HOST=127.0.0.1
Environment=PORT=3000
ExecStart=/usr/bin/node /opt/kartepe-simit/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
